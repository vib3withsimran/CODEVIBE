# Server Port (Default: 5002)
PORT=5002

# MongoDB Connection String
DB_URL=mongodb+srv://algocircuit2026_db_user:sayon12345@cluster0.io3sypg.mongodb.net/?appName=Cluster0
# Alternatively use MONGODB_URI
# MONGODB_URI=

# JWT Secret Key (Required for authentication)
# Generate a secure key by running: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# CORS Allowed Origins (Comma separated URLs)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# GitHub Leaderboard Sync (Optional)
LEADERBOARD_API_URL=
LEADERBOARD_API_TOKEN=