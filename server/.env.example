# =============================================================
# CODEVIBE — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit your actual .env file. It is already listed
# in .gitignore. This file (.env.example) is safe to commit.
# =============================================================


# -------------------------------------------------------------
# SERVER CONFIGURATION
# -------------------------------------------------------------

# Port the Express server runs on
PORT=5000

# Environment: development | production | test
NODE_ENV=development


# -------------------------------------------------------------
# DATABASE — MongoDB
# -------------------------------------------------------------

# Local MongoDB (for development)
MONGODB_URI=mongodb://localhost:27017/codevibe

# MongoDB Atlas (for production) — replace with your cluster URL
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/codevibe?retryWrites=true&w=majority


# -------------------------------------------------------------
# AUTHENTICATION — JSON Web Tokens
# -------------------------------------------------------------

# Secret key used to sign JWT tokens
# Use a long, random string in production (min 32 characters)
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=45779a3f17f0307f4af2d79b0962fd936592ac5084184fb5f23da9f6c17dff5a

# How long access tokens stay valid
# Examples: 7d (7 days), 24h (24 hours), 60m (60 minutes)
JWT_EXPIRES_IN=7d


# -------------------------------------------------------------
# CORS — Cross-Origin Resource Sharing
# -------------------------------------------------------------

# Frontend URL allowed to make requests to this server
# Development default is Vite's local dev server
CLIENT_URL=http://localhost:5173

# Production frontend URL (Netlify, Vercel, etc.)
# CLIENT_URL=https://codevibeforyou.netlify.app


# -------------------------------------------------------------
# CODE COMPILER — Execution Settings
# -------------------------------------------------------------

# Maximum time (ms) a submitted code snippet is allowed to run
COMPILER_TIMEOUT_MS=10000

# Temporary directory used to write and execute code files
# COMPILER_TEMP_DIR=/tmp/codevibe-compiler


# -------------------------------------------------------------
# EMAIL — Password Reset & Notifications (Future Feature)
# -------------------------------------------------------------
# Leave blank if email features are not yet enabled.

# SMTP host (e.g. smtp.gmail.com, smtp.sendgrid.net)
EMAIL_HOST=

# SMTP port: 587 for TLS, 465 for SSL
EMAIL_PORT=587

# SMTP login credentials
EMAIL_USER=
EMAIL_PASS=

# Sender address shown in outgoing emails
EMAIL_FROM=noreply@codevibe.dev
# Nodemailer Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_SERVICE=gmail
EMAIL_FROM=no-reply@codevibe.app
# Optional custom SMTP settings (use only if you want explicit SMTP instead of built-in Gmail service)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
DB_URL=mongodb+srv://<username>:<password>@cluster...

# CORS Configuration - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://codevibeforyou.netlify.app

# Server Port
PORT=5002

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=https://codevibeforyou.netlify.app

# GitHub Actions contributor leaderboard sync
LEADERBOARD_API_TOKEN=
