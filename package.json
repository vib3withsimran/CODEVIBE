{
  "name": "codevibe",
  "version": "1.0.0",
  "description": "CodeVibe - A learning platform",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs');['node_modules','client/node_modules','server/node_modules'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true});}catch(e){}});\"",
    "install-all": "npm install",
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "lint": "npm run lint --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  },
  "dependencies": {
    "mongodb": "^7.2.0"
  }
}
